[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/block_inspect_panel.gd" id="1_script"]

[node name="BlockInspectPanel" type="PanelContainer"]
script = ExtResource("1_script")
visible = false

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="InspectTitleLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Block Name"
horizontal_alignment = 1

[node name="HSep1" type="HSeparator" parent="Margin/VBox"]
layout_mode = 2

[node name="InspectStatsGrid" type="GridContainer" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 4
columns = 2

[node name="HSep2" type="HSeparator" parent="Margin/VBox"]
layout_mode = 2

[node name="InspectDescLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(160, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 11
autowrap_mode = 3
text = ""

[node name="Spacer" type="Control" parent="Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="InspectHintLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.5, 0.5, 0.5, 1)
text = "[Esc] back to build  •  [RMB] deselect"
horizontal_alignment = 1
autowrap_mode = 3
